{
  "$schema": "https://sapui5.hana.ondemand.com/sdk/resources/sap/ui/core/designtime/manifest.schema.json",
  "_version": "1.28.0",
  "sap.app": {
    "id": "customerindent.bulk",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.18.4",
      "toolsId": "c997b609-3904-4197-9f17-5adc44cc7b47"
    },
    "dataSources": {
      "mainService": {
        "uri": "/sap/opu/odata/sap/ZSD_CUST_BULK_INDENT_SRV/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "2.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "CustomerOrder-display": {
          "semanticObject": "CustomerOrder",
          "action": "display",
          "title": "{{CustomerOrder-display.flpTitle}}",
          "subTitle": "{{CustomerOrder-display.flpSubtitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.84.54",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {},
        "sap.ui.comp": {},
        "sap.suite.ui.commons": {}
      }
    },
    "componentUsages": {},
    "handleValidation": true,
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "customerindent.bulk.i18n.i18n"
        },
        "supportedLocales": [
          "en"
        ],
        "fallbackLocale": "en"
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "async": true,
        "viewPath": "customerindent.bulk.view",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "clearControlAggregation": false
      },
      "routes": [
        {
          "name": "RouteLogin",
          "pattern": "login",
          "target": [
            "TargetLogin"
          ]
        },
        {
          "name": "RouteCustomerIndent",
          "pattern": "",
          "target": [
            "TargetCustomerIndent"
          ]
        },
        {
          "name": "ManageBulkIndent",
          "pattern": "ManageBulkIndent/{vbeln}",
          "target": [
            "TargetManageBulkIndent"
          ]
        },
        {
          "name": "AddAgentDetails",
          "pattern": "AddAgentDetails",
          "target": [
            "TargetAddAgentDetails"
          ]
        }
      ],
      "targets": {
        "TargetLogin": {
          "viewType": "XML",
          "transition": "show",
          "clearControlAggregation": false,
          "viewId": "Login",
          "viewName": "Login"
        },
        "TargetCustomerIndent": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewId": "CustomerBulkIndent",
          "viewName": "CustomerBulkIndent"
        },
        "TargetManageBulkIndent": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewId": "ManageBulkIndent",
          "viewName": "ManageBulkIndent"
        },
        "TargetAddAgentDetails": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewId": "AddAgentDetails",
          "viewName": "AddAgentDetails"
        }
      }
    },
    "rootView": {
      "viewName": "customerindent.bulk.view.App",
      "type": "XML",
      "async": true,
      "id": "App"
    }
  }
}
