<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns="sap.m">

    <VBox class="manage-detail-card agent-form-card" id="addAgentFormCard">

        <VBox class="card-header">
            <Title text="{i18n>addAgent.formTitle}" class="card-title" />
        </VBox>

        <VBox class="card-content">

            <!-- Agent ID (auto-generated) -->
            <VBox class="detail-group">
                <Label text="{i18n>addAgent.agentId}" class="detail-label" />
                <Input
                    id="agentIdInput"
                    value="{addAgentModel>/AGENT_ID}"
                    maxLength="10"
                    width="100%"
                    editable="false"
                    class="sapUiReadOnlyField" />
            </VBox>

            <!-- Agent Name -->
            <VBox class="detail-group">
                <Label text="{i18n>addAgent.agentName}" class="detail-label required-label" />
                <Input
                    id="agentNameInput"
                    value="{addAgentModel>/AGENT_NAME}"
                    maxLength="35"
                    width="100%"
                    placeholder="{i18n>addAgent.agentNamePlaceholder}" />
            </VBox>

            <!-- Email -->
            <VBox class="detail-group">
                <Label text="{i18n>addAgent.agentMail}" class="detail-label required-label" />
                <Input
                    id="agentMailInput"
                    value="{addAgentModel>/AGENT_MAIL}"
                    maxLength="80"
                    width="100%"
                    type="Email"
                    placeholder="{i18n>addAgent.agentMailPlaceholder}" />
            </VBox>

            <!-- Phone -->
            <VBox class="detail-group">
                <Label text="{i18n>addAgent.agentPh}" class="detail-label required-label" />
                <Input
                    id="agentPhInput"
                    value="{addAgentModel>/AGENT_PH}"
                    maxLength="10"
                    width="100%"
                    type="Tel"
                    placeholder="{i18n>addAgent.agentPhPlaceholder}" />
            </VBox>

            <!-- Address -->
            <VBox class="detail-group">
                <Label text="{i18n>addAgent.agentAddr}" class="detail-label required-label" />
                <TextArea
                    id="agentAddrInput"
                    value="{addAgentModel>/AGENT_ADDR}"
                    maxLength="225"
                    rows="4"
                    growing="true"
                    width="100%"
                    placeholder="{i18n>addAgent.agentAddrPlaceholder}" />
            </VBox>

            <!-- Save Button -->
            <VBox class="detail-group" alignItems="End">
                <Button
                    text="{i18n>addAgent.btnSave}"
                    type="Emphasized"
                    icon="sap-icon://save"
                    width="100%"
                    press=".onSave" />
            </VBox>

        </VBox>
    </VBox>

</core:FragmentDefinition>
