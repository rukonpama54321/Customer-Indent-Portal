<mvc:View
    controllerName="customerindent.bulk.controller.CustomerBulkIndent"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">
    <Page
        title="Sales Document Lookup"
        showHeader="false"
        busy="{viewModel>/busy}">
        <content>
            <VBox width="100%">
                <VBox class="manage-header-section">
                    <HBox justifyContent="SpaceBetween" alignItems="Center" wrap="Wrap">
                        <HBox alignItems="Center" wrap="Wrap">
                            <Button
                                icon="sap-icon://nav-back"
                                type="Transparent"
                                tooltip="Back"
                                class="mastBackBtn sapUiTinyMarginEnd"
                                press=".onNavBack" />
                            <Image src="img/logo.png" alt="Logo" class="sapUiTinyMarginEnd" />
                            <VBox>
                                <Title text="Bulk Indent Portal" level="H1" class="manage-page-title" />
                                <Text text="Manage bulk indents for customers" class="manage-page-subtitle" />
                            </VBox>
                        </HBox>
                        <Button
                            text="Add Agent"
                            icon="sap-icon://add-employee"
                            type="Transparent"
                            class="addAgentHeaderBtn"
                            press=".onAddAgent" />
                    </HBox>
                </VBox>

                <IconTabBar
                    id="orderTabBar"
                    select=".onTabSelect">
                    <items>
                        <IconTabFilter text="Sales Documents" key="salesOrders" iconColor="Positive">
                            <items>
                                <IconTabFilter text="All Orders" key="allOrders" icon="sap-icon://list" iconColor="Default">
                                    <core:Fragment fragmentName="customerindent.bulk.view.CustomerBulkIndent.AllOrders" type="XML" />
                                </IconTabFilter>

                                <IconTabFilter text="Partially Assigned" key="partiallyAssigned" icon="sap-icon://status-in-process" iconColor="Critical">
                                    <core:Fragment fragmentName="customerindent.bulk.view.CustomerBulkIndent.PartiallyAssigned" type="XML" />
                                </IconTabFilter>

                                <IconTabFilter text="Fully Assigned" key="fullyAssigned" icon="sap-icon://complete" iconColor="Positive">
                                    <core:Fragment fragmentName="customerindent.bulk.view.CustomerBulkIndent.FullyAssigned" type="XML" />
                                </IconTabFilter>
                            </items>
                        </IconTabFilter>

                        <IconTabFilter text="Bulk Indents" key="createdOrders">
                            <core:Fragment fragmentName="customerindent.bulk.view.CustomerBulkIndent.BulkIndents" type="XML" />
                        </IconTabFilter>
                    </items>
                </IconTabBar>
            </VBox>
        </content>
    </Page>
</mvc:View>