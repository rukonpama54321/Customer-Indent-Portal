<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns="sap.m">

    <VBox
        class="agent-allocation-section"
        visible="{= ${manageModel>/orderCreated} &amp;&amp; (${manageModel>/thirdPartyAgent} === 'YES' || (${manageModel>/agentAllocations}.length > 0)) }">

        <VBox class="sapUiSmallMargin">
            <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                <Title text="Agent Allocations" level="H2" class="agent-allocation-title" />
                <Button
                    text="Add Agent"
                    type="Emphasized"
                    icon="sap-icon://add"
                    press=".onAddAgentAllocation"
                    visible="{= !${manageModel>/viewMode} }"
                    class="sapUiSmallMarginStart" />
                <ToolbarSpacer />
                <Button
                    text="Save Agent Details"
                    type="Accept"
                    icon="sap-icon://save"
                    press=".onSaveAgentAllocations"
                    visible="{= !${manageModel>/viewMode} }"
                    class="sapUiSmallMarginStart" />
            </HBox>

            <List
                items="{path: 'manageModel>/agentAllocations', templateShareable: true}"
                class="agent-allocations-list">
                <items>
                    <CustomListItem class="agent-allocation-item" type="Inactive">
                        <content>
                            <VBox width="100%">
                                <Panel
                                    expandable="true"
                                    expanded="{manageModel>__expanded}"
                                    class="agent-header-panel">
                                    <headerToolbar>
                                        <Toolbar>
                                            <Title
                                                text="{= (${manageModel>AGENT_NAME} || 'Unknown Agent') + ' - ' + (${manageModel>TRANS_NAME} || 'Unknown Transporter')}"
                                                level="H3" />
                                            <ToolbarSpacer />
                                            <Button
                                                icon="sap-icon://delete"
                                                type="Reject"
                                                press=".onDeleteAgentAllocation"
                                                visible="{= !${manageModel>/viewMode} }"
                                                tooltip="Delete this agent allocation" />
                                        </Toolbar>
                                    </headerToolbar>
                                    <content>
                                        <VBox class="agent-details-form">
                                            <HBox wrap="Wrap" class="sapUiSmallMarginBottom">

                                                <!-- Agent Selection -->
                                                <VBox class="detail-field" width="25%">
                                                    <Label text="Agent" class="detail-label required-label" />
                                                    <Text
                                                        text="{= (${manageModel>AGENT_NAME} || 'Unknown Agent') + (${manageModel>AGENT_ID} ? ' (' + ${manageModel>AGENT_ID} + ')' : '')}"
                                                        visible="{= !!${manageModel>_readonly} }"
                                                        class="detail-value" />
                                                    <ComboBox
                                                        selectedKey="{manageModel>AGENT_ID}"
                                                        placeholder="Select agent"
                                                        width="100%"
                                                        visible="{= !${manageModel>_readonly} }"
                                                        items="{path: 'manageModel>/agents', templateShareable: true}"
                                                        selectionChange=".onAgentChange">
                                                        <core:Item
                                                            key="{manageModel>AGENT_ID}"
                                                            text="{= (${manageModel>AGENT_NAME} || 'Unknown Agent') + (${manageModel>AGENT_ID} ? ' (' + ${manageModel>AGENT_ID} + ')' : '')}" />
                                                    </ComboBox>
                                                </VBox>

                                                <!-- Loading Date -->
                                                <VBox class="detail-field" width="25%">
                                                    <Label text="Loading Date" class="detail-label required-label" />
                                                    <Text
                                                        text="{manageModel>LOADING_DATE}"
                                                        visible="{= !!${manageModel>_readonly} }"
                                                        class="detail-value" />
                                                    <DatePicker
                                                        value="{manageModel>LOADING_DATE}"
                                                        valueFormat="yyyy-MM-dd"
                                                        displayFormat="long"
                                                        visible="{= !${manageModel>_readonly} }"
                                                        width="100%" />
                                                </VBox>

                                                <!-- Carrier Selection -->
                                                <VBox class="detail-field" width="25%">
                                                    <Label text="Carrier" class="detail-label" />
                                                    <Text
                                                        text="{manageModel>TRANS_NAME}"
                                                        visible="{= !!${manageModel>_readonly} }"
                                                        class="detail-value" />
                                                    <ComboBox
                                                        selectedKey="{manageModel>TRANSPORTER}"
                                                        placeholder="Select carrier"
                                                        width="100%"
                                                        visible="{= !${manageModel>_readonly} }"
                                                        items="{path: 'manageModel>/transporters', templateShareable: true}"
                                                        selectionChange=".onTransporterChange">
                                                        <core:Item key="{manageModel>CARRIER}" text="{manageModel>NAME}" />
                                                    </ComboBox>
                                                </VBox>

                                                <!-- Carrier GSTN -->
                                                <VBox class="detail-field" width="25%">
                                                    <Label text="Carrier GSTN" class="detail-label" />
                                                    <Text text="{manageModel>TRANSPORTGSTN}" class="detail-value" />
                                                </VBox>

                                            </HBox>

                                            <!-- Agent Items Allocation Table -->
                                            <VBox class="sapUiSmallMarginTop">
                                                <Title text="Item Allocations for this Agent" level="H4" class="sapUiSmallMarginBottom" />
                                                <Table
                                                    items="{path: 'manageModel>items', templateShareable: true}"
                                                    class="agent-items-table">
                                                    <columns>
                                                        <Column width="4rem"><Text text="Item" /></Column>
                                                        <Column width="9rem"><Text text="Material" /></Column>
                                                        <Column minScreenWidth="Desktop" demandPopin="true"><Text text="Description" /></Column>
                                                        <Column hAlign="End" width="7rem"><Text text="Order Qty" /></Column>
                                                        <Column hAlign="End" width="8rem"><Text text="Allocate Qty" /></Column>
                                                        <Column width="4rem"><Text text="UoM" /></Column>
                                                    </columns>
                                                    <items>
                                                        <ColumnListItem>
                                                            <cells>
                                                                <Text text="{manageModel>POSNR}" />
                                                                <Text text="{manageModel>MATNR}" />
                                                                <Text text="{manageModel>ARKTX}" />
                                                                <ObjectNumber
                                                                    number="{manageModel>KWMENG}"
                                                                    state="Information"
                                                                    emphasized="true" />
                                                                <Input
                                                                    value="{manageModel>agentQuantity}"
                                                                    type="Number"
                                                                    width="100%"
                                                                    editable="{= !${manageModel>_readonly} &amp;&amp; ${manageModel>availableQty} > 0 }"
                                                                    change=".onAgentItemQtyChange"
                                                                    tooltip="Enter quantity to allocate to this agent (cannot exceed available quantity)" />
                                                                <Text text="{manageModel>VRKME}" />
                                                            </cells>
                                                        </ColumnListItem>
                                                    </items>
                                                </Table>
                                            </VBox>
                                        </VBox>
                                    </content>
                                </Panel>
                            </VBox>
                        </content>
                    </CustomListItem>
                </items>
            </List>
        </VBox>
    </VBox>

</core:FragmentDefinition>
