<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns="sap.m">

    <!-- Search Criteria Panel -->
    <Panel headerText="Search Criteria" expandable="true" expanded="true">
        <content>
            <VBox class="sapUiSmallMargin">
                <HBox wrap="Wrap" alignItems="Start">
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="Customer Reference Date Range" />
                        <HBox>
                            <DatePicker
                                value="{viewModel>/fromDate}"
                                valueFormat="yyyy-MM-dd"
                                displayFormat="long"
                                width="14rem"
                                placeholder="From date"
                                class="sapUiTinyMarginEnd" />
                            <DatePicker
                                value="{viewModel>/toDate}"
                                valueFormat="yyyy-MM-dd"
                                displayFormat="long"
                                width="14rem"
                                placeholder="To date" />
                        </HBox>
                    </VBox>
                    <VBox class="sapUiSmallMarginEnd" width="20rem">
                        <Label text="Product (optional)" />
                        <ComboBox
                            selectedKey="{viewModel>/filterMaterial}"
                            placeholder="All Products"
                            width="100%"
                            items="{viewModel>/materialOptions}">
                            <core:Item key="{viewModel>MATNR}" text="{viewModel>text}" />
                        </ComboBox>
                        <Label
                            text="{viewModel>/uomHint}"
                            visible="{= !!${viewModel>/uomHint} }"
                            class="sapUiTinyMarginTop"
                            design="Standard" />
                    </VBox>
                    <VBox class="sapUiSmallMarginEnd" width="13rem">
                        <Label text="Min. Quantity (optional)" />
                        <Input
                            value="{viewModel>/filterQuantity}"
                            type="Number"
                            placeholder="Any quantity"
                            width="100%" />
                    </VBox>
                    <VBox>
                        <!-- Spacer keeps the button aligned with the input controls, not the labels -->
                        <Label text="&#160;" />
                        <Button
                            text="Search"
                            type="Emphasized"
                            icon="sap-icon://search"
                            press=".onSearch"
                            width="10rem" />
                    </VBox>
                </HBox>
            </VBox>
        </content>
    </Panel>

    <!-- Quick Filters Panel (visible only after search) -->
    <Panel
        headerText="Filters"
        expandable="true"
        expanded="true"
        visible="{= (${viewModel>/allHeaders} || []).length > 0 }">
        <content>
            <VBox class="sapUiSmallMargin">
                <HBox wrap="Wrap" alignItems="Center">
                    <VBox class="sapUiSmallMarginEnd" width="15rem">
                        <Label text="Shipping Condition" />
                        <ComboBox
                            selectedKey="{viewModel>/filterShippingCondition}"
                            placeholder="All"
                            width="100%"
                            selectionChange=".onShippingConditionFilter">
                            <items>
                                <core:Item key="" text="All" />
                                <core:Item key="CL" text="Collected (CL)" />
                                <core:Item key="DL" text="Delivered (DL)" />
                            </items>
                        </ComboBox>
                    </VBox>
                    <VBox class="sapUiSmallMarginEnd">
                        <Label text="Assignment Status" />
                        <ComboBox
                            selectedKey="{viewModel>/filterAssignmentStatus}"
                            placeholder="All"
                            width="15rem"
                            selectionChange=".onAssignmentStatusFilter">
                            <items>
                                <core:Item key="" text="All" />
                                <core:Item key="unassigned" text="Unassigned" />
                                <core:Item key="partial" text="Partially Assigned" />
                                <core:Item key="assigned" text="Fully Assigned" />
                            </items>
                        </ComboBox>
                    </VBox>
                </HBox>
            </VBox>
        </content>
    </Panel>

    <MessageStrip
        text="No sales documents found for the selected date range."
        type="Information"
        showIcon="true"
        visible="{viewModel>/showEmptyMessage}" />

    <VBox visible="{= ${viewModel>/headers}.length > 0 }">
        <Title text="Sales Documents" />
        <List
            id="salesOrderList"
            items="{viewModel>/headers}"
            mode="None">
            <items>
                <CustomListItem class="order-card-item" type="Active" press=".onHeaderToggle">
                    <content>
                        <VBox width="100%">
                            <HBox justifyContent="SpaceBetween" alignItems="Start" width="100%" class="order-header-section">
                                <VBox>
                                    <Title text="{viewModel>VBELN}" level="H3" />
                                    <Text text="{= 'Customer Ref: ' + (${viewModel>BSTNK} || '-') }" class="sapUiTinyMarginTop" />
                                    <Text text="{= 'Customer Ref Date: ' + (${viewModel>BSTDK} || '-') }" class="sapUiTinyMarginTop" />
                                    <Text text="{= 'Customer Code: ' + (${viewModel>KUNNR} || '-') }" class="sapUiTinyMarginTop" />
                                    <Text text="{= 'Delivery Location: ' + (${viewModel>DELIVLOC} || '-') }" class="sapUiTinyMarginTop" />
                                    <Text text="{= 'Delivery Date: ' + (${viewModel>DELIVDATE} ? ${viewModel>DELIVDATE}.substring(6,8) + '.' + ${viewModel>DELIVDATE}.substring(4,6) + '.' + ${viewModel>DELIVDATE}.substring(0,4) : '-') }" class="sapUiTinyMarginTop" />
                                    <ObjectStatus text="{path: 'viewModel>VSBED', formatter: '.formatShipping'}" state="Information" class="sapUiTinyMarginTop" />
                                    <Label text="Total Amount" class="detail-label sapUiTinyMarginTop" />
                                    <ObjectNumber
                                        number="{viewModel>NETWR}"
                                        unit="{viewModel>WAERK}"
                                        emphasized="false"
                                        class="order-net-value-small" />
                                </VBox>
                                <VBox alignItems="End">
                                    <ObjectStatus
                                        text="Fully Assigned"
                                        state="Success"
                                        icon="sap-icon://complete"
                                        visible="{viewModel>__isAssigned}"
                                        class="sapUiTinyMarginBottom assigned-order-badge" />
                                    <ObjectStatus
                                        text="Partially Assigned"
                                        state="Warning"
                                        icon="sap-icon://status-in-process"
                                        visible="{viewModel>__isPartiallyAssigned}"
                                        class="sapUiTinyMarginBottom" />
                                    <ObjectStatus
                                        text="Unassigned"
                                        state="None"
                                        icon="sap-icon://pending"
                                        visible="{= !${viewModel>__isAssigned} &amp;&amp; !${viewModel>__isPartiallyAssigned} }"
                                        class="sapUiTinyMarginBottom" />
                                </VBox>
                            </HBox>

                            <VBox visible="{viewModel>__expanded}" class="sapUiSmallMarginTop items-section-animated">
                                <Title text="Items" level="H4" class="sapUiSmallMarginBottom" />
                                <Table
                                    items="{path: 'viewModel>ToItem/results', templateShareable: false}"
                                    inset="false"
                                    class="order-items-table">
                                    <columns>
                                        <Column width="6rem"><Text text="ITEM" /></Column>
                                        <Column width="10rem"><Text text="MATERIAL" /></Column>
                                        <Column minScreenWidth="Tablet" demandPopin="true"><Text text="DESCRIPTION" /></Column>
                                        <Column hAlign="End" width="9rem"><Text text="QTY" /></Column>
                                        <Column width="5rem"><Text text="UOM" /></Column>
                                        <Column hAlign="End" width="9rem"><Text text="NET PRICE" /></Column>
                                        <Column width="5rem"><Text text="CURR" /></Column>
                                        <Column width="6rem"><Text text="PLANT" /></Column>
                                    </columns>
                                    <items>
                                        <ColumnListItem>
                                            <cells>
                                                <Text text="{viewModel>POSNR}" />
                                                <Text text="{viewModel>MATNR}" />
                                                <Text text="{viewModel>ARKTX}" />
                                                <Text text="{= ${viewModel>__showZeroQty} ? '0' : ${viewModel>KWMENG} }" />
                                                <Text text="{viewModel>VRKME}" />
                                                <Text text="{viewModel>NETPR}" />
                                                <Text text="{viewModel>WAERK}" />
                                                <Text text="{viewModel>WERKS}" />
                                            </cells>
                                        </ColumnListItem>
                                    </items>
                                </Table>
                            </VBox>

                            <HBox justifyContent="End" width="100%" visible="{viewModel>__expanded}" class="sapUiSmallMarginTop">
                                <Button
                                    text="Manage"
                                    type="Emphasized"
                                    press=".onManagePress"
                                    enabled="{= !${viewModel>__isAssigned} }"
                                    width="auto" />
                            </HBox>
                        </VBox>
                    </content>
                </CustomListItem>
            </items>
        </List>
    </VBox>

</core:FragmentDefinition>
