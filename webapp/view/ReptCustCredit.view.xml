<mvc:View
    controllerName="customerindent.controller.ReptCustCredit"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:layout="sap.ui.layout"
	xmlns:smartFilterBar="sap.ui.comp.smartfilterbar"
	xmlns:smartTable="sap.ui.comp.smarttable"
	xmlns:uiTable="sap.ui.table"
	xmlns:formatter="customerindent.util.formatter"
	xmlns:w="sap.ui.integration.widgets"
	xmlns:f="sap.f"
	xmlns:m="sap.m"
	xmlns:cards="sap.f.cards"
	xmlns:fb="sap.ui.comp.filterbar"
	xmlns:svm="sap.ui.comp.smartvariants"
    height="100%"><Page id="page4" title="Customer Credit Details" enableScrolling="false"><content><f:DynamicPage id="dynamicPage4"
                headerExpanded="true"
                toggleHeaderOnTitleClick="true"
                preserveHeaderStateOnScroll="false"><f:header><f:DynamicPageHeader pinnable="true"><f:content><fb:FilterBar id="filterbar_4" persistencyKey="myPersKey" 
                                useToolbar="false"
                                showGoOnFB="false" 
                                showFilterConfiguration="false"><fb:filterGroupItems><fb:FilterGroupItem id="_IDGenFilterGroupItem1_4" 
                                        name="StartDate" 
                                        label="Date" 
                                        groupName="Group2" 
                                        visibleInFilterBar="true" 
                                        mandatory="true"><fb:control><m:DatePicker
                                                id="idDateFrom4"
                                                valueFormat="yyyyMMdd"
                                                displayFormat="dd.MM.yyyy"
												placeholder="DD.MM.YYYY"
                                                change="onChangeStartDate"
                                                width="auto"/></fb:control></fb:FilterGroupItem><fb:FilterGroupItem id="_IDGenFilterGroupItem2_4" name="Credit Control Area" label="Credit Control Area"
                                                        groupName="Group2" visibleInFilterBar="true"><fb:control><Input id="iKKBER4" width="150px" value="1000" editable="false"/></fb:control></fb:FilterGroupItem><fb:FilterGroupItem id="_IDGenFilterGroupItem3_4" name="Customer Code" label="Customer Code"
                                                        groupName="Group2" visibleInFilterBar="true"><fb:control><Input id="iKunnr4" width="150px"  editable="false"/></fb:control></fb:FilterGroupItem></fb:filterGroupItems></fb:FilterBar><VBox><Button id="B1_4"
                                    type="Emphasized"
                                    text="Go"
                                    press="onSearch4"
                                    icon="sap-icon://initiative"/></VBox></f:content></f:DynamicPageHeader></f:header><f:content><VBox id="vboxTableBody_4" width="100%" height="100%"><Panel
                        headerText="{
                            parts: [
                                { path: 'tableData4>/Header/DATE_FROM' }
                            ],
                            formatter: '.formatter.creditformatdate'
                        }"
                        expandable="false"
                        width="100%"
                        backgroundDesign="Transparent"
                        class="sapUiSizeCompact"><HBox width="100%" justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom"><VBox><Text text="Customer Code: {tableData4>/Header/KUNNR}" wrapping="false" class="sapUiSmallMarginBottom"/><Text text="Name: {tableData4>/Header/NAME1}" wrapping="false" class="sapUiSmallMarginBottom"/></VBox><HBox class="sapUiTinyMarginBegin"><Button text="Download Excel" type="Emphasized" press="onDownloadExcel" /></HBox></HBox><VBox width="100%" height="100%"><ScrollContainer
                                height="500px"
                                width="100%"
                                horizontal="true"
                                vertical="true"
                                focusable="true"><Table id="idCustomerCreditReport_3"
                                    items="{tableData4>/CustomerCredit}"
                                    sticky="ColumnHeaders"
                                    alternateRowColors="true"
                                    width="100%"
                                    fixedLayout="false"
                                    growing="true"
                                    growingScrollToLoad="true"
                                    growingThreshold="100"><columns><Column><Text text="Credit Limit Allowed"/></Column><Column><Text text="Used Percentage"/></Column><Column><Text text="Available Credit"/></Column></columns><m:items><m:ColumnListItem vAlign="Middle"><m:cells><m:Text text="{tableData4>CREDITLIMIT}" wrapping="false" /><m:Text text="{tableData4>PERCENTAGE}" wrapping="false" /><m:Text text="{tableData4>AVAILABLE_CREDIT}" wrapping="false" /></m:cells></m:ColumnListItem></m:items></Table></ScrollContainer></VBox></Panel></VBox></f:content></f:DynamicPage></content></Page></mvc:View>
