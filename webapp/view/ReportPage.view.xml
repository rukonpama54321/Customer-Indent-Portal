<mvc:View xmlns:core="sap.ui.core" controllerName="customerindent.controller.ReportPage"
    xmlns:mvc="sap.ui.core.mvc" 
    displayBlock="true"
    xmlns="sap.m"
    xmlns:layout="sap.ui.layout"><Page title="Customer Reports" showHeader="false"><content><VBox class="ciMast"><HBox justifyContent="SpaceBetween" alignItems="Center" wrap="Wrap"><HBox alignItems="Center" wrap="Wrap"><Button icon="sap-icon://nav-back" type="Transparent" tooltip="Back to Customer Portal" class="ciMastBackBtn sapUiTinyMarginEnd" press=".onNavBack"/><Image src="img/logo.png" alt="NRL" class="ciMastLogo sapUiTinyMarginEnd"/><VBox><Title text="Customer Reports" level="H1" class="ciMastTitle"/><Text text="View and download customer reports" class="ciMastSubtitle"/></VBox></HBox></HBox></VBox><layout:Grid
        id="tileGrid"
        class="sapUiResponsiveContentPadding sapUiSmallMarginTop"
        defaultSpan="XL2 L3 M6 S12"
        hSpacing="0.5"
        vSpacing="1.5"
        width="100%"><layout:content><GenericTile header="Customer Indent"
                       subheader="Report of Customer Indent Data"
                       press="onCustIndentRept"><tileContent><TileContent><content><ImageContent src="{imgModel>/imgCustIndent}" /></content></TileContent></tileContent></GenericTile><GenericTile header="Customer Account Statement"
                       subheader="Report of Customer Account Statement"
                       press="onCustAccStmtRept"><tileContent><TileContent><content><ImageContent src="{imgModel>/imgAccStmt}"/></content></TileContent></tileContent></GenericTile><GenericTile header="Customer Credit Status"
                       subheader="Report of Customer Credit Status"
                       press="onCustCrdStatRept"><tileContent><TileContent><content><ImageContent src="{imgModel>/imgCreditStatus}"/></content></TileContent></tileContent></GenericTile><GenericTile header="Despatch Details"
                       subheader="Report of Despatch Details"
                       press="onCustDispDetRept"><tileContent><TileContent><content><ImageContent src="{imgModel>/imgDespatch}"/></content></TileContent></tileContent></GenericTile><GenericTile header="Account Reconciliation"
                       subheader="Report of Account Reconciliation"
                       press="onCustReconRept"><tileContent><TileContent><content><ImageContent src="{imgModel>/imgAccRecon}"/></content></TileContent></tileContent></GenericTile><GenericTile header="Valid Contract/Delivery Order"
                       subheader="Report of Valid Contract/Delivery Order"
                       press="onCustValidConRept"><tileContent><TileContent><content><ImageContent src="{imgModel>/imgValidContract}"/></content></TileContent></tileContent></GenericTile><GenericTile header="Closing Balance"
                       subheader="Report of Closing Balance"
                       press="onCustClosBalRept"><tileContent><TileContent><content><ImageContent src="{imgModel>/imgClosBal}"/></content></TileContent></tileContent></GenericTile><GenericTile header="Payment Details"
                       subheader="Report of Payment Details"
                       press="onCustPayDetRept"><tileContent><TileContent><content><ImageContent src="{imgModel>/imgPayDet}"/></content></TileContent></tileContent></GenericTile></layout:content></layout:Grid></content></Page></mvc:View>
